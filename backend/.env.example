# ── Flask ────────────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria
JWT_SECRET_KEY=otra-clave-secreta-distinta-para-jwt

# ── PostgreSQL ───────────────────────────────────────────────────
DATABASE_URL=postgresql://ryn_user:password@localhost:5432/rojoynaranja_db

# ── Admin (primer usuario del panel) ────────────────────────────
ADMIN_EMAIL=admin@rojoynaranja.com
ADMIN_PASSWORD=cambia-esta-password-antes-de-desplegar

# ── Gmail API (envío de emails de confirmación) ──────────────────
# Instrucciones: ver README.md → sección "Configurar Gmail API"
GMAIL_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=tu-client-secret
GMAIL_REFRESH_TOKEN=tu-refresh-token
GMAIL_SENDER_EMAIL=hola@rojoynaranja.com

# ── URLs ─────────────────────────────────────────────────────────
FRONTEND_URL=https://rojoynaranja.com
CORS_ORIGINS=https://rojoynaranja.com,http://localhost:3000
